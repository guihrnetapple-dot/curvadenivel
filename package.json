{
  "name": "agro-altimetria-pro",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c green,blue \"npm:dev:servidor\" \"npm:dev:cliente\"",
    "dev:cliente": "vite --host 127.0.0.1 --port 5173",
    "dev:servidor": "tsx watch servidor/src/servidor.ts",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p servidor/tsconfig.json --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "start:servidor": "tsx servidor/src/servidor.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.12",
    "@types/leaflet-draw": "^1.0.11",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.23",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3",
    "vite": "^5.2.6"
  }
}
